<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="controller.SeatController"
      style="-fx-background-color: #0d0d0d;">

    <!-- Navbar -->
    <HBox alignment="CENTER_LEFT" prefHeight="60"
          style="-fx-background-color: #111111; -fx-border-color: #222222;
                 -fx-border-width: 0 0 1 0; -fx-padding: 0 32;">
        <HBox alignment="CENTER_LEFT" spacing="12" HBox.hgrow="ALWAYS">
            <Label text="CINEMAX"
                   style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: white; -fx-letter-spacing: 6;"/>
            <Label text="●" style="-fx-text-fill: #e92000; -fx-font-size: 8px;"/>
            <Label text="Select Seats"
                   style="-fx-font-size: 12px; -fx-text-fill: #555555;"/>
        </HBox>
        <Button text="← Back" onAction="#goBack" prefHeight="36"
                style="-fx-background-color: transparent; -fx-text-fill: #444444; -fx-font-size: 11px;
                       -fx-padding: 0 16; -fx-border-color: #2a2a2a; -fx-border-radius: 6;
                       -fx-background-radius: 6; -fx-cursor: hand;"/>
    </HBox>

    <!-- Movie info bar -->
    <HBox alignment="CENTER_LEFT" prefHeight="46"
          style="-fx-background-color: #0a0a0a; -fx-padding: 0 32;
                 -fx-border-color: #1a1a1a; -fx-border-width: 0 0 1 0;">
        <Label fx:id="movieLabel"
               style="-fx-font-size: 13px; -fx-text-fill: #888888; -fx-font-weight: bold;"/>
    </HBox>

    <!-- Screen indicator -->
    <VBox alignment="CENTER" spacing="4" style="-fx-padding: 22 0 12 0;">
        <HBox prefHeight="3" maxWidth="480" alignment="CENTER"
              style="-fx-background-color: #e92000; -fx-background-radius: 2; -fx-opacity: 0.5;"/>
        <Label text="S  C  R  E  E  N"
               style="-fx-font-size: 9px; -fx-text-fill: #e92000; -fx-letter-spacing: 5;
                      -fx-font-weight: bold; -fx-opacity: 0.6;"/>
    </VBox>

    <!-- Seat grid -->
    <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                style="-fx-background: transparent; -fx-background-color: transparent;
                       -fx-border-color: transparent;">
        <GridPane fx:id="seatGrid" hgap="9" vgap="9" alignment="CENTER"
                  style="-fx-padding: 10 20; -fx-background-color: transparent;"/>
    </ScrollPane>

    <!-- Legend -->
    <HBox spacing="32" alignment="CENTER" style="-fx-padding: 10 0 12 0;">
        <HBox spacing="8" alignment="CENTER">
            <Label text="■" style="-fx-text-fill: #1a4a2a; -fx-font-size: 14px;"/>
            <Label text="Available" style="-fx-text-fill: #444444; -fx-font-size: 11px;"/>
        </HBox>
        <HBox spacing="8" alignment="CENTER">
            <Label text="■" style="-fx-text-fill: #e92000; -fx-font-size: 14px;"/>
            <Label text="Selected" style="-fx-text-fill: #444444; -fx-font-size: 11px;"/>
        </HBox>
        <HBox spacing="8" alignment="CENTER">
            <Label text="■" style="-fx-text-fill: #1a1a1a; -fx-font-size: 14px;"/>
            <Label text="Booked" style="-fx-text-fill: #444444; -fx-font-size: 11px;"/>
        </HBox>
    </HBox>

    <!-- Bottom action bar -->
    <HBox alignment="CENTER_LEFT" prefHeight="64" spacing="20"
          style="-fx-background-color: #111111; -fx-border-color: #1e1e1e;
                 -fx-border-width: 1 0 0 0; -fx-padding: 0 32;">
        <Label fx:id="statusLabel" HBox.hgrow="ALWAYS"
               style="-fx-font-size: 13px; -fx-text-fill: #444444; -fx-font-weight: bold;"/>
        <Button text="Proceed to Checkout  →" onAction="#goToCheckout"
                prefHeight="42" prefWidth="220"
                style="-fx-background-color: #e92000; -fx-text-fill: white; -fx-font-weight: bold;
                       -fx-font-size: 13px; -fx-background-radius: 8; -fx-cursor: hand;
                       -fx-effect: dropshadow(gaussian, rgba(233,32,0,0.314), 16, 0, 0, 4);"/>
    </HBox>
</VBox>
