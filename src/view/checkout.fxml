<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="controller.CheckoutController"
      style="-fx-background-color: #0d0d0d;">

    <!-- Navbar -->
    <HBox alignment="CENTER_LEFT" prefHeight="60"
          style="-fx-background-color: #111111; -fx-border-color: #222222;
                 -fx-border-width: 0 0 1 0; -fx-padding: 0 32;">
        <HBox alignment="CENTER_LEFT" spacing="12" HBox.hgrow="ALWAYS">
            <Label text="CINEMAX"
                   style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: white; -fx-letter-spacing: 6;"/>
            <Label text="●" style="-fx-text-fill: #e92000; -fx-font-size: 8px;"/>
            <Label text="Checkout"
                   style="-fx-font-size: 12px; -fx-text-fill: #555555;"/>
        </HBox>
        <Button text="← Back" onAction="#goBack" prefHeight="36"
                style="-fx-background-color: transparent; -fx-text-fill: #444444; -fx-font-size: 11px;
                       -fx-padding: 0 16; -fx-border-color: #2a2a2a; -fx-border-radius: 6;
                       -fx-background-radius: 6; -fx-cursor: hand;"/>
    </HBox>

    <StackPane VBox.vgrow="ALWAYS">
        <VBox maxWidth="480" alignment="CENTER" spacing="0"
              style="-fx-background-color: #111111; -fx-background-radius: 14;
                     -fx-border-color: #1e1e1e; -fx-border-radius: 14; -fx-border-width: 1;
                     -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.667), 40, 0, 0, 12);">

            <HBox prefHeight="4" minWidth="480"
                  style="-fx-background-color: #e92000; -fx-background-radius: 14 14 0 0;"/>

            <VBox spacing="18" style="-fx-padding: 28 32 32 32;">

                <VBox spacing="4">
                    <Label text="Booking Summary"
                           style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: white;"/>
                    <Label text="Review your order before confirming"
                           style="-fx-font-size: 11px; -fx-text-fill: #444444;"/>
                </VBox>

                <!-- Detail rows -->
                <VBox spacing="0"
                      style="-fx-background-color: #0a0a0a; -fx-background-radius: 10;
                             -fx-border-color: #1a1a1a; -fx-border-radius: 10; -fx-border-width: 1;">
                    <HBox style="-fx-padding: 13 16;">
                        <Label text="Movie" HBox.hgrow="ALWAYS"
                               style="-fx-font-size: 12px; -fx-text-fill: #444444;"/>
                        <Label fx:id="movieLabel"
                               style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: white;"/>
                    </HBox>
                    <Separator style="-fx-background-color: #1a1a1a;"/>
                    <HBox style="-fx-padding: 13 16;">
                        <Label text="Showtime" HBox.hgrow="ALWAYS"
                               style="-fx-font-size: 12px; -fx-text-fill: #444444;"/>
                        <Label fx:id="timeLabel"
                               style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #ff8c00;"/>
                    </HBox>
                    <Separator style="-fx-background-color: #1a1a1a;"/>
                    <HBox style="-fx-padding: 13 16;">
                        <Label text="Seats" HBox.hgrow="ALWAYS"
                               style="-fx-font-size: 12px; -fx-text-fill: #444444;"/>
                        <Label fx:id="seatsLabel"
                               style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #00b4d8;"/>
                    </HBox>
                    <Separator style="-fx-background-color: #1a1a1a;"/>
                    <HBox style="-fx-padding: 13 16;">
                        <Label text="Quantity" HBox.hgrow="ALWAYS"
                               style="-fx-font-size: 12px; -fx-text-fill: #444444;"/>
                        <Label fx:id="seatCountLabel"
                               style="-fx-font-size: 13px; -fx-text-fill: white;"/>
                    </HBox>
                    <Separator style="-fx-background-color: #1a1a1a;"/>
                    <HBox style="-fx-padding: 13 16;">
                        <Label text="Price per seat" HBox.hgrow="ALWAYS"
                               style="-fx-font-size: 12px; -fx-text-fill: #444444;"/>
                        <Label fx:id="priceLabel"
                               style="-fx-font-size: 13px; -fx-text-fill: white;"/>
                    </HBox>
                    <Separator style="-fx-background-color: #1a1a1a;"/>
                    <HBox style="-fx-padding: 13 16;">
                        <Label text="Booked by" HBox.hgrow="ALWAYS"
                               style="-fx-font-size: 12px; -fx-text-fill: #444444;"/>
                        <Label fx:id="userLabel"
                               style="-fx-font-size: 13px; -fx-text-fill: white;"/>
                    </HBox>
                </VBox>

                <!-- Total -->
                <HBox alignment="CENTER_LEFT" prefHeight="60"
                      style="-fx-background-color: #1a0000; -fx-background-radius: 10;
                             -fx-border-color: #3a0000; -fx-border-radius: 10; -fx-border-width: 1;
                             -fx-padding: 0 18;">
                    <VBox HBox.hgrow="ALWAYS" spacing="2">
                        <Label text="TOTAL AMOUNT"
                               style="-fx-font-size: 9px; -fx-font-weight: bold; -fx-text-fill: #555555; -fx-letter-spacing: 2;"/>
                        <Label text="All taxes included"
                               style="-fx-font-size: 10px; -fx-text-fill: #333333;"/>
                    </VBox>
                    <Label fx:id="totalLabel"
                           style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #e92000;"/>
                </HBox>

                <!-- Buttons -->
                <HBox spacing="10">
                    <Button text="Confirm and Pay" onAction="#confirmBooking"
                            HBox.hgrow="ALWAYS" maxWidth="Infinity" prefHeight="46"
                            style="-fx-background-color: #e92000; -fx-text-fill: white; -fx-font-weight: bold;
                                   -fx-font-size: 13px; -fx-background-radius: 8; -fx-cursor: hand;
                                   -fx-effect: dropshadow(gaussian, rgba(233,32,0,0.333), 16, 0, 0, 4);"/>
                    <Button text="Cancel" onAction="#goBack" prefWidth="90" prefHeight="46"
                            style="-fx-background-color: transparent; -fx-text-fill: #444444; -fx-font-size: 12px;
                                   -fx-border-color: #2a2a2a; -fx-border-radius: 8;
                                   -fx-background-radius: 8; -fx-cursor: hand;"/>
                </HBox>
            </VBox>
        </VBox>
    </StackPane>
</VBox>
